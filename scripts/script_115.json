  },
  {
    "id": 9,
    "offset": 349136,
    "slot_size": 238,
    "data_size": 234,
    "nom_orig": "Maya",
    "texte_orig": "Calm[SP]down,[SP]Yukki![SP]Fujii-san[SP]can[SP]take[SP]care[SP]of\nhimself,[SP]right?[SP]Rescuing[SP]him[SP]is[SP]just[SP]one[SP]more\nreason[SP]to[SP]hurry!",
