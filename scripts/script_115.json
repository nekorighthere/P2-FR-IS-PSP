    "offset": 348900,
    "slot_size": 236,
    "data_size": 232,
    "nom_orig": "Yukino",
    "texte_orig": "Did[SP]you[SP]say[SP]Mt.[SP]Katatsumuri!?[1205][001E][SP]Shunsuke-san's\nat[SP]the[SP]temple[SP]there![SP]If[SP]anything[SP]happens[SP]to\nhim,[SP]I'll...!",
