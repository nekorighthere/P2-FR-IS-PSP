  {
    "id": 3,
    "offset": 340740,
    "slot_size": 242,
    "data_size": 238,
    "nom_orig": "Eikichi",
    "texte_orig": "Really,[SP]it[SP]was[SP]just[SP]an[SP]excuse[SP]to[SP]beat[SP]people\nup[SP]with[SP]my[SP]Persona...[1205][001E][SP]And[SP]that[SP]ain't[SP]how[SP]a\nman[SP]should[SP]act!",
    "nom_fr": "Michel",
