    "offset": 341164,
    "slot_size": 202,
    "data_size": 198,
    "nom_orig": "Ginko",
    "texte_orig": "If[SP]nothing[SP]else,[SP]that[SP]stuff[SP]you[SP]said[SP]a[SP]second\nago[SP]was...[1205][001E][SP]Uhh...[SP]I-It[SP]was[SP]pretty[SP]cool!",
