  {
    "id": 16,
    "offset": 342982,
    "slot_size": 294,
    "data_size": 290,
    "nom_orig": "Leader",
    "texte_orig": "Th-The[SP]student[SP]council[SP]president[SP]asked[SP]me[SP]to!\nHe[SP]said[SP]he'd[SP]make[SP]me[SP]Leader[SP]with[SP]Master[SP]Joker's\npowers[SP]if[SP]I[SP]ruined[SP]Sevens'[SP]reputation!",
