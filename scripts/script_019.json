  {
    "id": 4,
    "offset": 340982,
    "slot_size": 182,
    "data_size": 178,
    "nom_orig": "Ginko",
    "texte_orig": "Aiyah!?[SP]What[SP]happened[SP]to[SP]the[SP]usual,[SP]self-\ncentered,[SP]heedless[SP]goon[SP]we[SP]all[SP]know?",
