  {
    "id": 15,
    "offset": 342790,
    "slot_size": 192,
    "data_size": 188,
    "nom_orig": "Yukino",
    "texte_orig": "Why'd[SP]you[SP]order[SP]your[SP]stooges[SP]to[SP]spread[SP]a\nrumor[SP]that[SP]the[SP]Sevens[SP]emblem[SP]was[SP]cursed?",
