    "offset": 342650,
    "slot_size": 140,
    "data_size": 136,
    "nom_orig": "Leader",
    "texte_orig": "Eep![SP]I-I'll[SP]talk,[SP]I'll[SP]talk![SP]What[SP]do[SP]you\nwant[SP]to[SP]know!?",
