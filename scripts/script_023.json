    "data_size": 142,
    "nom_orig": "Boy",
    "texte_orig": "This[SP]is[SP]my[SP]treasure.[SP]Papa[SP]gave[SP]it[SP]to[SP]me.[1205][001E]\nYou[SP]can[SP]have[SP]it,[SP][U+1113].",
