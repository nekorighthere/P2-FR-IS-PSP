  {
    "id": 9,
    "offset": 222076,
    "slot_size": 264,
    "data_size": 260,
    "nom_orig": "Drunk[SP]young[SP]man",
    "texte_orig": "Huh?[SP]You[SP]kids[SP]shouldn't[SP]be[SP]out[SP]so[SP]late.[1205][U+000A]\nYou'll[SP]never[SP]grow[SP]up[SP]to[SP]be[SP]upstanding\ncitizens[SP]like[SP]that,[SP]you[SP]know?",
