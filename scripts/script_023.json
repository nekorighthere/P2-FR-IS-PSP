  {
    "id": 8,
    "offset": 221926,
    "slot_size": 150,
    "data_size": 146,
    "nom_orig": "Drunk[SP]young[SP]man",
    "texte_orig": "Seeya,[SP]barkeep.[SP]I'll[SP]come[SP]again...\nYeah,[SP]I[SP]promise.",
