    "offset": 222340,
    "slot_size": 264,
    "data_size": 260,
    "nom_orig": "Drunk[SP]young[SP]man",
    "texte_orig": "Alright![1205][U+000A][SP]Looking[SP]good[SP]there,[SP]Kaoru,[SP]and[SP]not\nat[SP]all[SP]drunk.[SP]Looking[SP]like[SP]a[SP]man[SP]who's[SP]living\nup[SP]to[SP]his[SP]dreams.",
