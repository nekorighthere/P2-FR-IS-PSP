  {
    "id": 7,
    "offset": 221642,
    "slot_size": 284,
    "data_size": 280,
    "nom_orig": "Boy",
    "texte_orig": "Ahahahaha![SP]You're[SP]the[SP]greatest,[SP][U+1113]!\n[E1][E2][E4][NULL][NULL]\"Boy\nNo[SP]matter[SP]what[SP]happens,[SP]we're[SP]gonna[SP]keep[SP]our\npromise[SP]to[SP]each[SP]other![SP]Forever[SP]and[SP]ever!",
    "nom_fr": "Gamin",
    "texte_fr": "Ahahahaha! T’es le meilleur, [U+1113]!\nQuoi qu’il arrive… on va tenir notre promesse! Pour toujours et à jamais!"
