    "offset": 221318,
    "slot_size": 182,
    "data_size": 178,
    "nom_orig": "Boy",
    "texte_orig": "Isn't[SP]this...[1205][001E][SP]your[SP]treasure?[SP]I[SP]thought\nyour[SP]dad[SP]gave[SP]this[SP]to[SP]you.[SP]You[SP]can't...",
