  },
  {
    "id": 4,
    "offset": 221126,
    "slot_size": 192,
    "data_size": 188,
    "nom_orig": "Boy",
    "texte_orig": "It's[SP]okay.[SP]I[SP]mean,[SP]you're[SP]practically[SP]me.\nAnd[SP]I'm[SP]you.[SP]It'll[SP]be[SP]like[SP]I[SP]still[SP]have[SP]it!",
